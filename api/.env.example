# Local dev template — copy to .env and fill. .env is gitignored; NEVER commit secrets.
DATABASE_URL=postgresql+psycopg://lifeos:lifeos@localhost:5432/lifeos
PROCRASTINATE_DSN=postgresql://lifeos:lifeos@localhost:5432/lifeos   # libpq format for the worker queue

# AI — chat/vision/image-gen via OpenRouter (one key); embeddings + STT need their own keys
OPENROUTER_API_KEY=
VOYAGE_API_KEY=          # Voyage 4 embeddings (not on OpenRouter)
ELEVENLABS_API_KEY=      # Scribe v2 STT (not on OpenRouter)

# Sensitive-media encryption (AES-256, base64) — generate: openssl rand -base64 32
MEDIA_ENCRYPTION_KEY=

# Object storage — Cloudflare R2 (S3-compatible)
S3_ENDPOINT=             # https://<account>.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=lifeos-media
S3_REGION=auto

# Withings (see docs/research/withings-api.md)
WITHINGS_CLIENT_ID=
WITHINGS_CLIENT_SECRET=
WITHINGS_REDIRECT_URI=http://localhost:8000/withings/callback
