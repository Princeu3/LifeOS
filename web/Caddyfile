# Railway injects $PORT; Caddy serves the built PWA with SPA fallback.
:{$PORT:8080} {
	root * /srv
	encode gzip
	# Tight-ish CSP — with a localStorage bearer token, XSS is the main theft vector (see grounding).
	# connect/img allow the API origin; no Permissions-Policy so WebAuthn (publickey-credentials) works.
	header {
		Content-Security-Policy "default-src 'self'; connect-src 'self' https://api-production-507b.up.railway.app; img-src 'self' https://api-production-507b.up.railway.app data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'; worker-src 'self'; manifest-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "no-referrer"
		X-Frame-Options "DENY"
	}
	try_files {path} /index.html
	file_server
}
